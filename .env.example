# ---------------------------------------------------------------------------
# Copy this file to `.env.local` for local development.
# On Vercel: Project → Settings → Environment Variables (Production + Preview).
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ---------------------------------------------------------------------------

# Canonical site URL (no trailing slash). Used for SEO metadata, sitemap,
# robots.txt, Open Graph and JSON-LD.
# Local:  http://localhost:3000
# Vercel: https://your-domain.com  (or your *.vercel.app URL)
NEXT_PUBLIC_SITE_URL="https://nivethith.dev"

# Search engine verification tokens (optional).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
NEXT_PUBLIC_BING_SITE_VERIFICATION=""

# ---------------------------------------------------------------------------
# Supabase — contact form storage
# Project URL: https://cnkrxtqeyfgtmdakzuzi.supabase.co
# Get keys from: Supabase Dashboard → Project Settings → API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://cnkrxtqeyfgtmdakzuzi.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"
# Recommended on Vercel (server-only — never prefix with NEXT_PUBLIC_):
# Enables shared rate limiting across serverless instances.
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---------------------------------------------------------------------------
# Email delivery via Resend (https://resend.com)
# 1. Create an API key at https://resend.com/api-keys
# 2. Sandbox: you can only email the Resend account owner, and
#    CONTACT_FROM_EMAIL can stay "Portfolio <onboarding@resend.dev>"
# 3. Production: verify a domain at https://resend.com/domains, then set
#    CONTACT_FROM_EMAIL="Portfolio <noreply@yourdomain.com>"
# ---------------------------------------------------------------------------
RESEND_API_KEY=""
CONTACT_TO_EMAIL="nivethith.16@gmail.com"
CONTACT_FROM_EMAIL="Portfolio <onboarding@resend.dev>"
